# The Observatory — environment variables (names only; never commit real values)

# --- Database (Neon Postgres via Vercel Marketplace) ---
# Set automatically by the Vercel Neon integration. The app falls back to the
# static data/*.json when neither is present, so these are optional in dev.
POSTGRES_URL=
DATABASE_URL=

# --- Client: point the graph at the live API instead of static JSON ---
# When set (e.g. "/api/graph"), the browser hydrates the graph from the backend.
NEXT_PUBLIC_GRAPH_API=

# --- Notion sync (canonical export layer, gated by Status=Public) ---
# The sync reads two purpose-built Notion DBs (not the operational ones):
#   "Observatory Entities"      → org/event/project/initiative nodes
#   "Observatory Relationships" → typed edges between entities
NOTION_TOKEN=
OBSERVATORY_ENTITIES_DB_ID=
OBSERVATORY_RELATIONSHIPS_DB_ID=

# --- Protect the sync route (cron/manual). Vercel cron is allowed automatically. ---
CRON_SECRET=
